{% comment %} Custom Product Grid Section {% endcomment %}

<section class="custom-grid">
  <h2 class="grid-title">{{ section.settings.grid_title }}</h2>

  <div class="grid-container">
    {% for block in section.blocks %}
      {% assign product = all_products[block.settings.product] %}
      <div class="grid-item" {{ block.shopify_attributes }}>
        <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
        <button
          class="grid-plus-btn"
          data-product-id="{{ product.id }}"
          data-product-title="{{ product.title }}"
          data-product-price="{{ product.price | money }}"
          data-product-description="{{ product.description | strip_html | truncate: 120 }}"
          data-product-image="{{ product.featured_image | img_url: 'large' }}"
          data-product-variants="{{ product.variants | json | escape }}"
          data-product-options="{{ product.options_with_values | json | escape }}"
          onclick="cpgOpenPopup(this)"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="6" y1="0" x2="6" y2="12" stroke="currentColor" stroke-width="1.5"/>
            <line x1="0" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</section>

{% comment %} ═══════════════════════════════════════════
     QUICK VIEW POPUP (Figma Design)
     ═══════════════════════════════════════════ {% endcomment %}

<div class="cpg-overlay" id="cpgOverlay" onclick="cpgClosePopup()"></div>

<div class="cpg-popup" id="cpgPopup">
  <button class="cpg-close" onclick="cpgClosePopup()">✕</button>

  <!-- Top: Image + Product Info -->
  <div class="cpg-top">
    <img id="cpgImage" src="" alt="">
    <div class="cpg-info">
      <h3 id="cpgTitle"></h3>
      <p id="cpgPrice" class="cpg-price"></p>
      <p id="cpgDesc" class="cpg-desc"></p>
    </div>
  </div>

  <!-- Dynamic Options (Color / Size) -->
  <div id="cpgOptions"></div>

  <!-- Add to Cart (Frontend Only) -->
  <button class="cpg-atc" id="cpgAtcBtn" onclick="cpgAddToCart()">
    <span class="cpg-atc-text">ADD TO CART</span>
    <span class="cpg-atc-arrow">→</span>
  </button>
</div>

<style>
  /* ============================================================
     GRID LAYOUT — PRESERVED EXACTLY AS BEFORE
     ============================================================ */
  .custom-grid {
    padding: 60px 40px;
    background: #fff;
  }

  .grid-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 30px;
    color: #000;
  }

  .grid-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .grid-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .grid-item img {
    width: 100%;
    height: 350px;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .grid-item:hover img {
    transform: scale(1.03);
  }

  /* ============================================================
     PLUS BUTTON — replaces old dot button
     White circle with + icon on each product image
     ============================================================ */
  .grid-plus-btn {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    border: 1.5px solid rgba(0, 0, 0, 0.15);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    z-index: 2;
    color: #333;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .grid-plus-btn:hover {
    background: #000;
    color: #fff;
    border-color: #000;
    transform: scale(1.1);
  }

  /* ============================================================
     POPUP OVERLAY
     ============================================================ */
  .cpg-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1000;
    backdrop-filter: blur(2px);
  }

  /* ============================================================
     POPUP BOX — matches Figma layout
     ============================================================ */
  .cpg-popup {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #fff;
    width: 400px;
    max-width: 92vw;
    max-height: 90vh;
    overflow-y: auto;
    z-index: 1001;
    padding: 28px 28px 0 28px;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.18);
  }

  .cpg-close {
    position: absolute;
    top: 14px;
    right: 18px;
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: #000;
    z-index: 2;
    padding: 4px;
    line-height: 1;
  }

  .cpg-close:hover {
    opacity: 0.5;
  }

  /* ── Top section: image + info side by side ── */
  .cpg-top {
    display: flex;
    gap: 16px;
    margin-bottom: 24px;
    padding-right: 20px;
  }

  .cpg-top img {
    width: 120px;
    height: 140px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .cpg-info {
    flex: 1;
    min-width: 0;
  }

  .cpg-info h3 {
    font-size: 16px;
    font-weight: 500;
    font-style: italic;
    margin: 0 0 8px 0;
    color: #000;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .cpg-price {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 10px 0;
    color: #000;
  }

  .cpg-desc {
    font-size: 12px;
    color: #555;
    line-height: 1.55;
    margin: 0;
  }

  /* ============================================================
     COLOR SELECTOR — Figma design
     Two side-by-side boxes with colored left border stripe.
     Selected = black background + white text.
     ============================================================ */
  .cpg-opt-group {
    margin-bottom: 20px;
  }

  .cpg-opt-label {
    font-size: 13px;
    font-weight: 400;
    color: #000;
    margin: 0 0 8px 0;
  }

  .cpg-color-wrap {
    display: flex;
    border: 1px solid #000;
    overflow: hidden;
  }

  .cpg-color-btn {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: #fff;
    border: none;
    border-right: 1px solid #ccc;
    cursor: pointer;
    font-size: 14px;
    font-weight: 400;
    color: #000;
    position: relative;
    transition: background 0.2s ease, color 0.2s ease;
    text-align: left;
    min-height: 44px;
  }

  .cpg-color-btn:last-child {
    border-right: none;
  }

  /* Colored stripe on the left edge of each color option */
  .cpg-color-stripe {
    position: absolute;
    left: 0;
    top: 0;
    width: 5px;
    height: 100%;
  }

  .cpg-color-btn-text {
    margin-left: 12px;
  }

  /* Selected color: black background, white text */
  .cpg-color-btn.active {
    background: #000;
    color: #fff;
  }

  /* ============================================================
     SIZE DROPDOWN — Figma design
     Custom dropdown with "Choose your size" + chevron.
     Expands to show XS, S, M, L, XL options.
     ============================================================ */
  .cpg-size-dropdown {
    position: relative;
  }

  .cpg-size-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #fff;
    border: 1px solid #000;
    cursor: pointer;
    font-size: 14px;
    color: #000;
    box-sizing: border-box;
  }

  .cpg-size-toggle:hover {
    background: #fafafa;
  }

  .cpg-chevron {
    font-size: 14px;
    transition: transform 0.25s ease;
    user-select: none;
  }

  .cpg-size-toggle.open .cpg-chevron {
    transform: rotate(180deg);
  }

  .cpg-size-list {
    display: none;
    border: 1px solid #000;
    border-top: none;
    background: #fff;
    max-height: 220px;
    overflow-y: auto;
  }

  .cpg-size-list.open {
    display: block;
  }

  .cpg-size-option {
    width: 100%;
    padding: 12px 16px;
    background: #fff;
    border: none;
    border-bottom: 1px solid #eee;
    cursor: pointer;
    font-size: 14px;
    text-align: center;
    color: #000;
    transition: background 0.15s ease;
    box-sizing: border-box;
  }

  .cpg-size-option:last-child {
    border-bottom: none;
  }

  .cpg-size-option:hover {
    background: #f5f5f5;
  }

  .cpg-size-option.active {
    background: #000;
    color: #fff;
  }

  /* ============================================================
     ADD TO CART BUTTON — Frontend only
     ============================================================ */
  .cpg-atc {
    width: calc(100% + 56px);
    margin-left: -28px;
    margin-top: 24px;
    padding: 18px 28px;
    background: #000;
    color: #fff;
    border: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: background 0.3s ease;
  }

  .cpg-atc:hover {
    background: #333;
  }

  .cpg-atc.added {
    background: #2d7a3e;
  }

  .cpg-atc-arrow {
    font-size: 18px;
    font-weight: 300;
  }

  /* ============================================================
     MOBILE RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .grid-container {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid-item img {
      height: 200px;
    }

    .custom-grid {
      padding: 30px 16px;
    }

    .cpg-popup {
      width: 95vw;
      padding: 20px 20px 0 20px;
    }

    .cpg-top {
      flex-direction: column;
    }

    .cpg-top img {
      width: 100%;
      height: 200px;
    }

    .cpg-atc {
      width: calc(100% + 40px);
      margin-left: -20px;
    }
  }
</style>

<script>
  /* ============================================================
     QUICK VIEW POPUP — JavaScript
     ============================================================ */

  // State
  let cpgSelectedOptions = {};
  let cpgCurrentProduct = null;

  /**
   * Color name → CSS hex mapping for the left stripe
   */
  function cpgGetColorHex(name) {
    const map = {
      'blue': '#1a3a8a',
      'black': '#000000',
      'red': '#8b0023',
      'grey': '#999999',
      'gray': '#999999',
      'white': '#cccccc',
      'green': '#2d6b2d',
      'brown': '#6b3a1e',
      'navy': '#1a2744',
      'beige': '#c8b89a',
      'pink': '#d4668e',
      'yellow': '#c4a800',
      'orange': '#cc6600',
      'purple': '#5c2d82',
      'cream': '#d4c9a8',
      'tan': '#c2a36e',
      'maroon': '#5a0020',
      'teal': '#1a6b6b',
      'olive': '#556b2f',
      'coral': '#cd5b45',
    };
    return map[name.toLowerCase().trim()] || '#333333';
  }

  /**
   * Open the quick-view popup
   */
  function cpgOpenPopup(btn) {
    const title = btn.dataset.productTitle;
    const price = btn.dataset.productPrice;
    const description = btn.dataset.productDescription;
    const image = btn.dataset.productImage;
    const options = JSON.parse(btn.dataset.productOptions);

    cpgCurrentProduct = { title, price, description, image, options };
    cpgSelectedOptions = {};

    // Populate popup content
    document.getElementById('cpgTitle').textContent = title;
    document.getElementById('cpgPrice').textContent = price;
    document.getElementById('cpgDesc').textContent = description;
    document.getElementById('cpgImage').src = image;

    // Build color + size options
    cpgBuildOptions(options);

    // Reset Add to Cart button
    const atcBtn = document.getElementById('cpgAtcBtn');
    atcBtn.classList.remove('added');
    atcBtn.disabled = false;
    atcBtn.querySelector('.cpg-atc-text').textContent = 'ADD TO CART';

    // Show popup
    document.getElementById('cpgOverlay').style.display = 'block';
    document.getElementById('cpgPopup').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  /**
   * Build color and size option controls dynamically
   */
  function cpgBuildOptions(options) {
    const container = document.getElementById('cpgOptions');
    container.innerHTML = '';

    options.forEach(function(option) {
      const group = document.createElement('div');
      group.className = 'cpg-opt-group';

      // Label (e.g., "Color" or "Size")
      const label = document.createElement('p');
      label.className = 'cpg-opt-label';
      label.textContent = option.name;
      group.appendChild(label);

      const isSize = option.name.toLowerCase().includes('size');

      if (isSize) {
        /* ─────────────────────────────────────────
           CUSTOM SIZE DROPDOWN (Figma design)
           ───────────────────────────────────────── */
        const dropdown = document.createElement('div');
        dropdown.className = 'cpg-size-dropdown';

        // Toggle button
        const toggle = document.createElement('button');
        toggle.className = 'cpg-size-toggle';
        toggle.type = 'button';
        toggle.innerHTML = '<span class="cpg-size-text">Choose your size</span><span class="cpg-chevron">∨</span>';

        // Dropdown list
        const list = document.createElement('div');
        list.className = 'cpg-size-list';

        option.values.forEach(function(val) {
          const opt = document.createElement('button');
          opt.className = 'cpg-size-option';
          opt.type = 'button';
          opt.textContent = val;

          opt.onclick = function() {
            // Deselect all, select this one
            list.querySelectorAll('.cpg-size-option').forEach(function(o) {
              o.classList.remove('active');
            });
            opt.classList.add('active');
            cpgSelectedOptions[option.name] = val;

            // Update toggle text and close dropdown
            toggle.querySelector('.cpg-size-text').textContent = val;
            list.classList.remove('open');
            toggle.classList.remove('open');
          };

          list.appendChild(opt);
        });

        // Toggle open/close
        toggle.onclick = function() {
          const isOpen = list.classList.contains('open');
          if (isOpen) {
            list.classList.remove('open');
            toggle.classList.remove('open');
          } else {
            list.classList.add('open');
            toggle.classList.add('open');
          }
        };

        dropdown.appendChild(toggle);
        dropdown.appendChild(list);
        group.appendChild(dropdown);

      } else {
        /* ─────────────────────────────────────────
           COLOR SELECTOR (Figma design)
           Two boxes with colored left stripe.
           Selected = black bg + white text.
           ───────────────────────────────────────── */
        const wrap = document.createElement('div');
        wrap.className = 'cpg-color-wrap';

        option.values.forEach(function(val, i) {
          const btn = document.createElement('button');
          btn.className = 'cpg-color-btn' + (i === 0 ? ' active' : '');
          btn.type = 'button';

          // Colored stripe
          const stripe = document.createElement('span');
          stripe.className = 'cpg-color-stripe';
          stripe.style.backgroundColor = cpgGetColorHex(val);

          // Color name text
          const text = document.createElement('span');
          text.className = 'cpg-color-btn-text';
          text.textContent = val;

          btn.appendChild(stripe);
          btn.appendChild(text);

          // Default first option as selected
          if (i === 0) cpgSelectedOptions[option.name] = val;

          btn.onclick = function() {
            wrap.querySelectorAll('.cpg-color-btn').forEach(function(b) {
              b.classList.remove('active');
            });
            btn.classList.add('active');
            cpgSelectedOptions[option.name] = val;
          };

          wrap.appendChild(btn);
        });

        group.appendChild(wrap);
      }

      container.appendChild(group);
    });
  }

  /**
   * Close popup
   */
  function cpgClosePopup() {
    document.getElementById('cpgOverlay').style.display = 'none';
    document.getElementById('cpgPopup').style.display = 'none';
    document.body.style.overflow = '';

    // Close any open size dropdowns
    document.querySelectorAll('.cpg-size-list.open').forEach(function(el) {
      el.classList.remove('open');
    });
    document.querySelectorAll('.cpg-size-toggle.open').forEach(function(el) {
      el.classList.remove('open');
    });
  }

  /**
   * Add to Cart — Frontend only (visual confirmation)
   * Per test requirements: just shows frontend feedback, no actual cart API call.
   */
  function cpgAddToCart() {
    const btn = document.getElementById('cpgAtcBtn');
    const textEl = btn.querySelector('.cpg-atc-text');
    const arrowEl = btn.querySelector('.cpg-atc-arrow');

    // Show "Added" feedback
    textEl.textContent = 'ADDED TO CART';
    arrowEl.textContent = '✓';
    btn.classList.add('added');
    btn.disabled = true;

    // Reset after 1.5s and close popup
    setTimeout(function() {
      textEl.textContent = 'ADD TO CART';
      arrowEl.textContent = '→';
      btn.classList.remove('added');
      btn.disabled = false;
      cpgClosePopup();
    }, 1500);
  }

  /**
   * Close dropdown when clicking outside
   */
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.cpg-size-dropdown')) {
      document.querySelectorAll('.cpg-size-list.open').forEach(function(el) {
        el.classList.remove('open');
      });
      document.querySelectorAll('.cpg-size-toggle.open').forEach(function(el) {
        el.classList.remove('open');
      });
    }
  });

  /**
   * Close popup on Escape key
   */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') cpgClosePopup();
  });
</script>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "grid_title",
      "label": "Section Title",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid"
    }
  ]
}
{% endschema %}