</style>

<script>
  /* ============================================================
     QUICK VIEW POPUP — JavaScript
     ============================================================ */

  // State
  let cpgSelectedOptions = {};
  let cpgCurrentProduct = null;

  /**
   * Color name → CSS hex mapping for the left stripe
   */
  function cpgGetColorHex(name) {
    const map = {
      'blue': '#1a3a8a',
      'black': '#000000',
      'red': '#8b0023',
      'grey': '#999999',
      'gray': '#999999',
      'white': '#cccccc',
      'green': '#2d6b2d',
      'brown': '#6b3a1e',
      'navy': '#1a2744',
      'beige': '#c8b89a',
      'pink': '#d4668e',
      'yellow': '#c4a800',
      'orange': '#cc6600',
      'purple': '#5c2d82',
      'cream': '#d4c9a8',
      'tan': '#c2a36e',
      'maroon': '#5a0020',
      'teal': '#1a6b6b',
      'olive': '#556b2f',
      'coral': '#cd5b45',
    };
    return map[name.toLowerCase().trim()] || '#333333';
  }

  /**
   * Open the quick-view popup
   */
  function cpgOpenPopup(btn) {
    const title = btn.dataset.productTitle;
    const price = btn.dataset.productPrice;
    const description = btn.dataset.productDescription;
    const image = btn.dataset.productImage;
    const options = JSON.parse(btn.dataset.productOptions);

    cpgCurrentProduct = { title, price, description, image, options };
    cpgCurrentProduct.variantData = btn.dataset.productVariants;
    cpgSelectedOptions = {};

    // Populate popup content
    document.getElementById('cpgTitle').textContent = title;
    document.getElementById('cpgPrice').textContent = price;
    document.getElementById('cpgDesc').textContent = description;
    document.getElementById('cpgImage').src = image;

    // Build color + size options
    cpgBuildOptions(options);

    // Reset Add to Cart button
    const atcBtn = document.getElementById('cpgAtcBtn');
    atcBtn.classList.remove('added');
    atcBtn.disabled = false;
    atcBtn.querySelector('.cpg-atc-text').textContent = 'ADD TO CART';

    // Show popup
    document.getElementById('cpgOverlay').style.display = 'block';
    document.getElementById('cpgPopup').style.display = 'block';
    document.body.style.overflow = 'hidden';
  }

  /**
   * Build color and size option controls dynamically
   */
  function cpgBuildOptions(options) {
    const container = document.getElementById('cpgOptions');
    container.innerHTML = '';

    // Sort: Color/non-size options first, then Size options (matches Figma order)
    var sorted = options.slice().sort(function(a, b) {
      var aIsSize = a.name.toLowerCase().includes('size') ? 1 : 0;
      var bIsSize = b.name.toLowerCase().includes('size') ? 1 : 0;
      return aIsSize - bIsSize;
    });

    sorted.forEach(function(option) {
      const group = document.createElement('div');
      group.className = 'cpg-opt-group';

      // Label (e.g., "Color" or "Size")
      const label = document.createElement('p');
      label.className = 'cpg-opt-label';
      label.textContent = option.name;
      group.appendChild(label);

      const isSize = option.name.toLowerCase().includes('size');

      if (isSize) {
      
        const dropdown = document.createElement('div');
        dropdown.className = 'cpg-size-dropdown';

        // Toggle button
        const toggle = document.createElement('button');
        toggle.className = 'cpg-size-toggle';
        toggle.type = 'button';
        toggle.innerHTML = '<span class="cpg-size-text">Choose your size</span><span class="cpg-chevron">∨</span>';

        // Dropdown list
        const list = document.createElement('div');
        list.className = 'cpg-size-list';

        option.values.forEach(function(val) {
          const opt = document.createElement('button');
          opt.className = 'cpg-size-option';
          opt.type = 'button';
          opt.textContent = val;

          opt.onclick = function() {
            // Deselect all, select this one
            list.querySelectorAll('.cpg-size-option').forEach(function(o) {
              o.classList.remove('active');
            });
            opt.classList.add('active');
            cpgSelectedOptions[option.name] = val;

            // Update toggle text and close dropdown
            toggle.querySelector('.cpg-size-text').textContent = val;
            list.classList.remove('open');
            toggle.classList.remove('open');
          };

          list.appendChild(opt);
        });

        // Toggle open/close
        toggle.onclick = function() {
          const isOpen = list.classList.contains('open');
          if (isOpen) {
            list.classList.remove('open');
            toggle.classList.remove('open');
          } else {
            list.classList.add('open');
            toggle.classList.add('open');
          }
        };

        dropdown.appendChild(toggle);
        dropdown.appendChild(list);
        group.appendChild(dropdown);

      } else {
       
        const wrap = document.createElement('div');
        wrap.className = 'cpg-color-wrap';

        option.values.forEach(function(val, i) {
          const btn = document.createElement('button');
          btn.className = 'cpg-color-btn' + (i === 0 ? ' active' : '');
          btn.type = 'button';

          // Colored stripe
          const stripe = document.createElement('span');
          stripe.className = 'cpg-color-stripe';
          stripe.style.backgroundColor = cpgGetColorHex(val);

          // Color name text
          const text = document.createElement('span');
          text.className = 'cpg-color-btn-text';
          text.textContent = val;

          btn.appendChild(stripe);
          btn.appendChild(text);

          // Default first option as selected
          if (i === 0) cpgSelectedOptions[option.name] = val;

          btn.onclick = function() {
            wrap.querySelectorAll('.cpg-color-btn').forEach(function(b) {
              b.classList.remove('active');
            });
            btn.classList.add('active');
            cpgSelectedOptions[option.name] = val;
          };

          wrap.appendChild(btn);
        });

        group.appendChild(wrap);
      }

      container.appendChild(group);
    });
  }

  /**
   * Close popup
   */
  function cpgClosePopup() {
    document.getElementById('cpgOverlay').style.display = 'none';
    document.getElementById('cpgPopup').style.display = 'none';
    document.body.style.overflow = '';

    // Close any open size dropdowns
    document.querySelectorAll('.cpg-size-list.open').forEach(function(el) {
      el.classList.remove('open');
    });
    document.querySelectorAll('.cpg-size-toggle.open').forEach(function(el) {
      el.classList.remove('open');
    });
  }

  /**
   * Add to Cart — Real Shopify Cart API
   * 1. Finds matching variant from selected options
   * 2. Adds to Shopify cart via /cart/add.js
   * 3. If Black + Medium selected → also adds Soft Winter Jacket
   */
  function cpgAddToCart() {
    const btn = document.getElementById('cpgAtcBtn');
    const textEl = btn.querySelector('.cpg-atc-text');
    const arrowEl = btn.querySelector('.cpg-atc-arrow');

    // Get variants from the currently open product button
    const activeBtn = document.querySelector('.grid-plus-btn[data-product-variants]');
    const allBtns = document.querySelectorAll('.grid-plus-btn');
    
    // Find the button that opened this popup by matching title
    let currentBtn = null;
    allBtns.forEach(function(b) {
      if (b.dataset.productTitle === cpgCurrentProduct.title) {
        currentBtn = b;
      }
    });

    if (!currentBtn) {
      alert('Something went wrong. Please try again.');
      return;
    }

    // Parse variants from button data
    const variants = JSON.parse(cpgCurrentProduct.variantData || '[]');

    // Find matching variant based on selected options
    const matchedVariant = variants.find(function(variant) {
      return Object.keys(cpgSelectedOptions).every(function(optName) {
        return variant.title.toLowerCase().includes(
          cpgSelectedOptions[optName].toLowerCase()
        );
      });
    });

    if (!matchedVariant) {
      alert('Please select all options before adding to cart!');
      return;
    }

    // Disable button while processing
    btn.disabled = true;
    textEl.textContent = 'ADDING...';

    // Build items array
    const items = [{ id: matchedVariant.id, quantity: 1 }];

    // Check special rule: Black + Medium → also add Soft Winter Jacket
    const selectedColor = (cpgSelectedOptions['Color'] || '').toLowerCase();
    const selectedSize = (cpgSelectedOptions['Size'] || '').toLowerCase();
    const isBlack = selectedColor === 'black';
    const isMedium = selectedSize === 'm' || selectedSize === 'medium';

    if (isBlack && isMedium) {
      // Fetch Soft Winter Jacket product then add both
      fetch('/products/soft-winter-jacket.js')
        .then(function(r) { return r.json(); })
        .then(function(jacket) {
          items.push({ id: jacket.variants[0].id, quantity: 1 });
          cpgPostToCart(items, btn, textEl, arrowEl);
        })
        .catch(function() {
          // If jacket not found just add main product
          cpgPostToCart(items, btn, textEl, arrowEl);
        });
    } else {
      cpgPostToCart(items, btn, textEl, arrowEl);
    }
  }

  /**
   * POST items to Shopify Cart API
   */
  function cpgPostToCart(items, btn, textEl, arrowEl) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: items })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.status && data.status !== 200) {
        throw new Error(data.description || 'Cart error');
      }
      // Success feedback
      textEl.textContent = 'ADDED TO CART';
      arrowEl.textContent = '✓';
      btn.classList.add('added');

      // Redirect to cart after short delay
      setTimeout(function() {
        window.location.href = '/cart';
      }, 800);
    })
    .catch(function(err) {
      console.error('Cart error:', err);
      textEl.textContent = 'ADD TO CART';
      arrowEl.textContent = '→';
      btn.disabled = false;
      alert('Could not add to cart. Please try again.');
    });
  }

  /**
   * Close dropdown when clicking outside
   */
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.cpg-size-dropdown')) {
      document.querySelectorAll('.cpg-size-list.open').forEach(function(el) {
        el.classList.remove('open');
      });
      document.querySelectorAll('.cpg-size-toggle.open').forEach(function(el) {
        el.classList.remove('open');
      });
    }
  });

  /**
   * Close popup on Escape key
   */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') cpgClosePopup();
  });
</script>

