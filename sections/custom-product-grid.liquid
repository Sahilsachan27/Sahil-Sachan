{% comment %} Custom Product Grid Section {% endcomment %}

<section class="custom-grid">
  <h2 class="grid-title">{{ section.settings.grid_title }}</h2>

  <div class="grid-container">
    {% for block in section.blocks %}
      {% assign product = all_products[block.settings.product] %}
      <div class="grid-item" {{ block.shopify_attributes }}>
        <img src="{{ product.featured_image | img_url: 'master' }}" alt="{{ product.title }}">
        <button
          class="grid-plus-btn"
          data-product-id="{{ product.id }}"
          data-product-title="{{ product.title }}"
          data-product-price="{{ product.price | money }}"
          data-product-description="{{ product.description | strip_html | truncate: 120 }}"
          data-product-image="{{ product.featured_image | img_url: 'large' }}"
          data-product-variants="{{ product.variants | json | escape }}"
          data-product-options="{{ product.options_with_values | json | escape }}"
          onclick="cpgOpenPopup(this)"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <line x1="6" y1="0" x2="6" y2="12" stroke="currentColor" stroke-width="1.5"/>
            <line x1="0" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </button>
      </div>
    {% endfor %}
  </div>
</section>


<div class="cpg-overlay" id="cpgOverlay" onclick="cpgClosePopup()"></div>

<div class="cpg-popup" id="cpgPopup">
  <button class="cpg-close" onclick="cpgClosePopup()">✕</button>

  <!-- Top: Image + Product Info -->
  <div class="cpg-top">
    <img id="cpgImage" src="" alt="">
    <div class="cpg-info">
      <h3 id="cpgTitle"></h3>
      <p id="cpgPrice" class="cpg-price"></p>
      <p id="cpgDesc" class="cpg-desc"></p>
    </div>
  </div>

  <!-- Dynamic Options (Color / Size) -->
  <div id="cpgOptions"></div>

  <!-- Add to Cart (Frontend Only) -->
  <button class="cpg-atc" id="cpgAtcBtn" onclick="cpgAddToCart()">
    <span class="cpg-atc-text">ADD TO CART</span>
    <span class="cpg-atc-arrow">→</span>
  </button>
</div>

<style>
 
  .cpg-popup,
  .cpg-popup *,
  .cpg-popup h3,
  .cpg-popup p,
  .cpg-popup button,
  .cpg-popup span,
