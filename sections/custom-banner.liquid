{% comment %} Custom Banner Section {% endcomment %}

{% comment %} Custom Banner Section {% endcomment %}

{%- liquid
  assign logo_text = section.settings.logo_text | default: 'TISSO VISON'
  assign tagline = section.settings.tagline | default: 'Find the ideal gift for your loved ones.'
  assign yellow_btn_text = section.settings.yellow_button_text | default: 'CHOOSE GIFT'
  assign yellow_btn_link = section.settings.yellow_button_link | default: '#'
  assign heading = section.settings.heading | default: 'The Gift Guide'
  assign description = section.settings.description | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.'
  assign black_btn_text = section.settings.black_button_text | default: 'SHOP NOW'
  assign black_btn_link = section.settings.black_button_link | default: '#'
  assign footer_text = section.settings.footer_text | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL'
-%}

<section class="custom-banner-section">
  <!-- Top Navigation Bar -->
  <div class="cb-top-bar">
    <div class="cb-top-left">
      <span class="cb-logo">{{ logo_text }}</span>
    </div>
    <div class="cb-top-center">
      <span class="cb-tagline">{{ tagline }}</span>
    </div>
    <div class="cb-top-right">
      <a href="{{ yellow_btn_link }}" class="cb-yellow-btn">
        {{ yellow_btn_text }} <span>→</span>
      </a>
    </div>
  </div>

  <!-- Main Banner Area -->
  <div class="cb-main-area">
    {% if section.settings.bg_image != blank %}
    <div class="cb-illustration">
      {{ section.settings.bg_image | image_url: width: 2000 | image_tag: alt: section.settings.bg_image.alt, class: 'bg-image-el', loading: 'lazy' }}
    </div>
    {% endif %}
    
    <div class="cb-content">
      <h1 class="cb-heading">{{ heading }}</h1>
      <p class="cb-description">{{ description }}</p>
      
      <a href="{{ black_btn_link }}" class="cb-black-btn">
        {{ black_btn_text }} <span>→</span>
      </a>
    </div>
  </div>

  <!-- Footer Banner -->
  <div class="cb-footer">
    <p>{{ footer_text }}</p>
  </div>
</section>

<style>
  .custom-banner-section {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    margin: 0;
    padding: 0;
  }

  /* Top Bar */
  .cb-top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 5%;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
  }

  .cb-top-left {
    flex: 1;
    display: flex;
    justify-content: flex-start;
  }

  .cb-top-center {
    flex: 2;
    display: flex;
    justify-content: center;
    text-align: center;
  }

  .cb-top-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }

  .cb-logo {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #000;
  }

  .cb-tagline {
    font-size: 14px;
    color: #333;
  }

  .cb-yellow-btn {
    display: inline-flex;
    align-items: center;
    background: #FFD700;
    color: #000;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .cb-yellow-btn:hover {
    background: #e6c200;
  }

  .cb-yellow-btn span {
    margin-left: 8px;
    transition: transform 0.2s ease;
  }

  .cb-yellow-btn:hover span {
    transform: translateX(4px);
  }

  /* Main Area */
  .cb-main-area {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    padding: 80px 5%;
    box-sizing: border-box;
    overflow: hidden;
    background: #fff;
  }

  .cb-illustration {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .bg-image-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
  }

  .cb-content {
    position: relative;
    z-index: 2;
    max-width: 480px;
    background: linear-gradient(90deg, rgba(255,255,255,0.95) 40%, rgba(255,255,255,0.7) 70%, rgba(255,255,255,0) 100%);
    padding: 30px 40px 30px 0;
    border-radius: 8px;
  }

  .cb-heading {
    font-size: 56px;
    font-weight: 700;
    margin: 0 0 20px 0;
    color: #000;
    line-height: 1.1;
  }

  .cb-description {
    font-size: 16px;
    color: #333;
    line-height: 1.6;
    margin: 0 0 35px 0;
  }

  .cb-black-btn {
    display: inline-flex;
    align-items: center;
    background: #000;
    color: #fff;
    padding: 14px 36px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .cb-black-btn:hover {
    background: #333;
  }

  .cb-black-btn span {
    margin-left: 12px;
    transition: transform 0.2s ease;
  }

  .cb-black-btn:hover span {
    transform: translateX(4px);
  }

  /* Footer */
  .cb-footer {
    background: #f8f8f8;
    padding: 15px 20px;
    text-align: center;
    border-top: 1px solid #eee;
  }

  .cb-footer p {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    color: #666;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cb-top-bar {
      flex-direction: column;
      gap: 15px;
      padding: 20px;
    }
    .cb-main-area {
      padding: 50px 5%;
    }
    .cb-content {
      padding: 20px;
      background: rgba(255, 255, 255, 0.9);
      max-width: 100%;
    }
    .cb-heading {
      font-size: 40px;
    }
    .cb-illustration {
      opacity: 0.3;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "header",
      "content": "Navigation Bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Center Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "yellow_button_text",
      "label": "Yellow Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "yellow_button_link",
      "label": "Yellow Button Link"
    },
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "black_button_text",
      "label": "Black Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "black_button_link",
      "label": "Black Button Link"
    },
    {
      "type": "header",
      "content": "Footer & Background"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Illustration"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}