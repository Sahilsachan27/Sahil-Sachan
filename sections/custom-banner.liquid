{% comment %}
  ============================================================
  CUSTOM BANNER SECTION
  ============================================================
  Layout: Nav (50px) + Top Image (245px) + Bottom Image (245px) + Footer (40px) = 580px
  
  HOW TO ADJUST:
  ── Banner total height ──
  Change .cb-hero height (currently 490px) and the two band heights (.cb-top, .cb-bot = 245px each).
  
  ── Move images left/right ──
  Change object-position on .cb-top img or .cb-bot img.
  Values: "left center", "center center", "right center", "20% center", etc.
  
  ── Move images up/down ──
  Change object-position on .cb-top img or .cb-bot img.
  Values: "center top", "center center", "center bottom", "center 30%", etc.
  
  ── Resize images (zoom in/out) ──
  Change object-fit on .cb-top img or .cb-bot img.
  "cover" = fill container (may crop). "contain" = show full image (may letterbox).
  
  ── Move text left/right ──
  Change left on .cb-text. Currently 40px. Set to 80px to push right, 20px to push left.
  
  ── Move text up/down ──
  Change top on .cb-text. Currently 50%. Set to 30% for higher, 70% for lower.
  
  ── Make banner full screen width ──
  Already set. If it's not full width, Dawn is constraining it.
  The fix is on .cb-section-reset which sets width:100vw and negative margins.
  ============================================================
{% endcomment %}

{%- liquid
  assign logo_text   = section.settings.logo_text           | default: 'TISSO VISON'
  assign tagline     = section.settings.tagline              | default: 'Find the ideal gift for your loved ones.'
  assign y_btn_text  = section.settings.yellow_button_text   | default: 'CHOOSE GIFT'
  assign y_btn_link  = section.settings.yellow_button_link   | default: '#'
  assign heading     = section.settings.heading              | default: 'The Gift Guide'
  assign description = section.settings.description          | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.'
  assign b_btn_text  = section.settings.black_button_text    | default: 'SHOP NOW'
  assign b_btn_link  = section.settings.black_button_link    | default: '#'
  assign footer_text = section.settings.footer_text          | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL'
-%}

<style>
  /* ============================================================
     DAWN THEME OVERRIDE
     Dawn wraps every section in #shopify-section-{{ section.id }}.
     It applies CSS variables (--color-background, etc.) that can
     cause black/yellow backgrounds. We override ALL of them here.
     ============================================================ */
  #shopify-section-{{ section.id }} {
    --color-background: 255, 255, 255 !important;
    --gradient-background: #ffffff !important;
    --color-foreground: 0, 0, 0 !important;
    background: #ffffff !important;
    background-color: #ffffff !important;
    max-width: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* ============================================================
     FULL-WIDTH RESET
     Dawn puts sections inside a max-width container. This breaks
     out of that container so the banner spans the full viewport.
     ============================================================ */
  .cb-section-reset {
    width: 100vw !important;
    max-width: 100vw !important;
    margin-left: calc(-50vw + 50%) !important;
    /* ── Side compression: 4% padding on left+right to match Figma inset ── */
    /* Increase to 5% or 6% for more compression, decrease to 2% for less */
    padding: 0 4% !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    background: #ffffff !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
    position: relative !important;
    z-index: 2 !important;
  }

  /* ============================================================
     NAV BAR – 50px fixed height
     ============================================================ */
  .cb-nav {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    height: 50px !important;
    max-height: 50px !important;
    min-height: 50px !important;
    padding: 0 40px !important;
    background: #ffffff !important;
    border-bottom: 1px solid #e8e8e8 !important;
    box-sizing: border-box !important;
    overflow: hidden !important;
    /* Keep nav above Dawn's header */
    position: relative !important;
    z-index: 10 !important;
  }

  .cb-logo {
    font-size: 15px !important;
    font-weight: 800 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    color: #000 !important;
    flex-shrink: 0 !important;
    flex-grow: 0 !important;
    height: auto !important;
    max-height: 50px !important;
    background: transparent !important;
    /* CRITICAL: Dawn calculates insane line-height from --font-body-scale */
    line-height: 1.2 !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
  }

  .cb-tagline {
    font-size: 14px !important;
    color: #333 !important;
    text-align: center !important;
    flex: 1 1 auto !important;
    padding: 0 20px !important;
    height: auto !important;
    max-height: 50px !important;
    background: transparent !important;
    /* CRITICAL: Dawn calculates insane line-height from --font-body-scale */
    line-height: 1.4 !important;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif !important;
  }

  /* Yellow button — CHOOSE GIFT
     NOTE: height/max-height are critical to prevent Dawn's 25-million-px bug */
  .cb-ybtn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: #FFD600 !important;
    background-color: #FFD600 !important;
    color: #000 !important;
    padding: 10px 22px !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    flex-shrink: 0 !important;
    flex-grow: 0 !important;
    /* CRITICAL: prevent Dawn from stretching this to millions of px */
    height: auto !important;
    max-height: 40px !important;
    min-height: unset !important;
    min-width: unset !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    transition: background 0.2s ease, letter-spacing 0.25s ease !important;
    position: relative !important;
  }
  /* Kill Dawn's ::before and ::after overlays on buttons */
  .cb-ybtn::before,
  .cb-ybtn::after { content: none !important; display: none !important; }
  .cb-ybtn:hover { background: #e6c000 !important; letter-spacing: 0.12em !important; }

  /* ============================================================
     HERO WRAPPER – contains two image bands
     ── FULL VIEWPORT HEIGHT ──
     calc(100vh - 90px) = viewport minus nav(50px) minus footer(40px)
     ── To make shorter: replace calc(100vh - 90px) with a fixed px ──
     ============================================================ */
  .cb-hero {
    width: 100% !important;
    height: calc(100vh - 90px) !important;
    max-height: calc(100vh - 90px) !important;
    min-height: calc(100vh - 90px) !important;
    display: block !important;
    overflow: hidden !important;
    background: #ffffff !important;
    position: relative !important;
    box-sizing: border-box !important;
  }

  /* ============================================================
     TOP BAND – 245px – pure illustration, no text
     ── Move image: change object-position below ──
     ============================================================ */
  .cb-top {
    width: 100% !important;
    /* ── TOP BAND HEIGHT: 50% of hero ── */
    /* Change to 40% or 60% to shift the split point */
    /* ── TOP BAND = 45% of hero (matches Figma proportions) ── */
    height: 50% !important;
    max-height: 50% !important;
    min-height: 50% !important;
    position: relative !important;
    overflow: hidden !important;
    display: block !important;
    background: #ffffff !important;
    box-sizing: border-box !important;
  }
  .cb-top-img {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    /* "cover" fills and crops edges — items bleed off naturally */
    object-fit: cover !important;
    /* Shifted down to match Figma — items sit lower in the band */
    object-position: center 40% !important;
    display: block !important;
    max-width: none !important;
    border: none !important;
  }

  /* ============================================================
     BOTTOM BAND – 245px – illustration + text overlay
     ── Move image: change object-position below ──
     ============================================================ */
  .cb-bot {
    width: 100% !important;
    /* ── BOTTOM BAND HEIGHT: 50% of hero ── */
    /* Change to 60% (if top is 40%) to give more space for text */
    /* ── BOTTOM BAND = 55% of hero (more space for text overlay) ── */
    height: 50% !important;
    max-height: 50% !important;
    min-height: 50% !important;
    position: relative !important;
    overflow: hidden !important;
    display: block !important;
    background: #ffffff !important;
    box-sizing: border-box !important;
  }
  .cb-bot-img {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    /* "cover" fills and crops — bottom items partially disappear */
    object-fit: cover !important;
    /* Shifted right + lower to match Figma — clear left space for text */
    object-position: 75% 60% !important;
    display: block !important;
    max-width: none !important;
    border: none !important;
    z-index: 0 !important;
  }

  /* White gradient overlay – makes text readable over the image */
  .cb-gradient {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    /* ── Gradient: fades from white (left) to transparent (right) ── */
    /* Adjust the percentages to control how far the white extends */
    background: linear-gradient(
      to right,
      rgba(255,255,255,1.00) 0%,
      rgba(255,255,255,1.00) 25%,
      rgba(255,255,255,0.92) 38%,
      rgba(255,255,255,0.65) 50%,
      rgba(255,255,255,0.00) 65%
    ) !important;
    z-index: 1 !important;
    pointer-events: none !important;
  }

  /* ============================================================
     TEXT OVERLAY – heading, description, SHOP NOW button
     ── Move left/right: change "left" below ──
     ── Move up/down: change "top" below ──
     ============================================================ */
  .cb-text {
    position: absolute !important;
    /* ── Vertical position: 50% = centered. Use 30% for higher, 70% for lower ── */
    top: 50% !important;
    /* ── Horizontal position: 80px from left edge (Figma match) ── */
    left: 80px !important;
    transform: translateY(-50%) !important;
    z-index: 2 !important;
    /* ── Max width of text block. Increase for wider text area ── */
    max-width: 380px !important;
    background: transparent !important;
    height: auto !important;
    max-height: none !important;
  }

  .cb-heading {
    font-size: 46px !important;
    font-weight: 800 !important;
    line-height: 1.05 !important;
    color: #000 !important;
    margin: 0 0 12px 0 !important;
    padding: 0 !important;
    background: transparent !important;
    height: auto !important;
    max-height: none !important;
  }

  .cb-desc {
    font-size: 14px !important;
    line-height: 1.6 !important;
    color: #222 !important;
    margin: 0 0 20px 0 !important;
    padding: 0 !important;
    background: transparent !important;
    height: auto !important;
    max-height: none !important;
  }

  /* Black button — SHOP NOW */
  .cb-bbtn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: #000000 !important;
    background-color: #000000 !important;
    color: #ffffff !important;
    padding: 12px 26px !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em !important;
    text-transform: uppercase !important;
    text-decoration: none !important;
    /* CRITICAL: prevent Dawn from stretching this to millions of px */
    height: auto !important;
    max-height: 44px !important;
    min-height: unset !important;
    min-width: unset !important;
    border: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    transition: background 0.2s ease, letter-spacing 0.25s ease !important;
    position: relative !important;
  }
  .cb-bbtn::before,
  .cb-bbtn::after { content: none !important; display: none !important; }
  .cb-bbtn:hover { background: #333333 !important; letter-spacing: 0.12em !important; }

  /* ============================================================
     FOOTER BAR – 40px
     ============================================================ */
  .cb-footer {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    height: 40px !important;
    max-height: 40px !important;
    min-height: 40px !important;
    background: #efefef !important;
    border-top: 1px solid #ddd !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    color: #555 !important;
    overflow: hidden !important;
    box-sizing: border-box !important;
  }

  /* ============================================================
     MOBILE NAV — Hamburger menu (hidden on desktop)
     ============================================================ */
  .cb-hamburger {
    display: none !important; /* hidden on desktop */
  }
  .cb-mobile-panel {
    display: none !important; /* hidden on desktop */
  }

  /* ============================================================
     RESPONSIVE – Tablet
     ============================================================ */
  @media (max-width: 1024px) {
    .cb-text {
      left: 40px !important;
      max-width: 45% !important;
    }
    .cb-heading { font-size: 36px !important; }
  }

  /* ============================================================
     RESPONSIVE – Mobile (≤768px)
     ============================================================ */
  @media (max-width: 768px) {
    .cb-section-reset {
      padding: 0 !important;
    }

    /* --- Desktop nav hidden on mobile --- */
    .cb-tagline { display: none !important; }
    .cb-ybtn { display: none !important; }

    .cb-nav {
      height: 50px !important;
      max-height: 50px !important;
      min-height: 50px !important;
      padding: 0 16px !important;
      justify-content: center !important;
      position: relative !important;
    }
    .cb-logo {
      text-align: center !important;
      font-size: 16px !important;
    }

    /* --- Hamburger icon visible on mobile --- */
    .cb-hamburger {
      display: flex !important;
      position: absolute !important;
      left: 16px !important;
      top: 50% !important;
      transform: translateY(-50%) !important;
      background: none !important;
      background-color: transparent !important;
      border: none !important;
      cursor: pointer !important;
      font-size: 22px !important;
      color: #000 !important;
      padding: 4px !important;
      width: auto !important;
      height: auto !important;
      min-width: unset !important;
      min-height: unset !important;
      line-height: 1 !important;
      z-index: 5 !important;
    }
    .cb-hamburger::before,
    .cb-hamburger::after { content: none !important; display: none !important; }

    /* --- Mobile slide-down panel --- */
    .cb-mobile-panel {
      display: none;
      flex-direction: column !important;
      align-items: center !important;
      padding: 20px 24px 24px !important;
      background: #fff !important;
      border-bottom: 1px solid #e8e8e8 !important;
      gap: 16px !important;
    }
    .cb-mobile-panel.open {
      display: flex !important;
    }
    .cb-mobile-tagline {
      font-size: 14px !important;
      color: #333 !important;
      text-align: center !important;
      line-height: 1.5 !important;
      height: auto !important;
      background: transparent !important;
    }
    .cb-mobile-ybtn {
      display: inline-flex !important;
      align-items: center !important;
      justify-content: center !important;
      background: #e8d44d !important;
      background-color: #e8d44d !important;
      color: #000 !important;
      padding: 14px 40px !important;
      font-size: 14px !important;
      font-weight: 700 !important;
      letter-spacing: 0.08em !important;
      text-transform: uppercase !important;
      text-decoration: none !important;
      border: none !important;
      height: auto !important;
      min-height: unset !important;
      min-width: unset !important;
      line-height: 1.2 !important;
    }
    .cb-mobile-ybtn::before,
    .cb-mobile-ybtn::after { content: none !important; display: none !important; }

    /* --- Hero: auto height on mobile --- */
    .cb-hero {
      height: auto !important;
      max-height: none !important;
      min-height: unset !important;
    }

    /* --- Top band: hide on mobile (Figma mobile has no top image) --- */
    .cb-top {
      display: none !important;
    }

    /* --- Bottom band: full layout on mobile --- */
    .cb-bot {
      height: auto !important;
      max-height: none !important;
      min-height: unset !important;
    }

    /* Text section: centered, above image on mobile */
    .cb-text {
      position: relative !important;
      transform: none !important;
      left: auto !important;
      top: auto !important;
      padding: 30px 24px 20px !important;
      max-width: 100% !important;
      text-align: center !important;
      z-index: 2 !important;
      background: #fff !important;
    }
    .cb-heading {
      font-size: 32px !important;
      text-align: center !important;
    }
    .cb-desc {
      font-size: 14px !important;
      text-align: center !important;
    }
    .cb-bbtn {
      margin: 0 auto !important;
    }

    /* Gradient: hide on mobile since text is on white bg above image */
    .cb-gradient {
      display: none !important;
    }

    /* Bottom image: show below text, partially visible */
    .cb-bot-img {
      position: relative !important;
      width: 100% !important;
      height: 250px !important;
      object-position: center center !important;
    }

    /* Footer */
    .cb-footer {
      font-size: 9px !important;
      letter-spacing: 0.06em !important;
      padding: 0 12px !important;
    }
  }

  /* ============================================================
     RESPONSIVE – Small phones (≤480px)
     ============================================================ */
  @media (max-width: 480px) {
    .cb-bot-img {
      height: 200px !important;
    }
    .cb-heading { font-size: 26px !important; }
    .cb-desc { font-size: 13px !important; }
    .cb-text { padding: 24px 20px 16px !important; }
    .cb-bbtn { padding: 10px 22px !important; font-size: 11px !important; }
  }
</style>

<!-- ══════════════════════════════════════════════════
     HTML STRUCTURE
     ══════════════════════════════════════════════════ -->
<div class="cb-section-reset">

  <!-- NAV BAR -->
  <div class="cb-nav">
    <button class="cb-hamburger" onclick="document.querySelector('.cb-mobile-panel').classList.toggle('open'); var ic = this.querySelector('.cb-hamburger-icon'); ic.textContent = ic.textContent === '✕' ? '☰' : '✕';" aria-label="Menu"><span class="cb-hamburger-icon">☰</span></button>
    <span class="cb-logo">{{ logo_text }}</span>
    <span class="cb-tagline">{{ tagline }}</span>
    <a href="{{ y_btn_link }}" class="cb-ybtn">{{ y_btn_text }}&nbsp;&nbsp;&#8594;</a>
  </div>

  <!-- MOBILE SLIDE-DOWN PANEL (hidden on desktop) -->
  <div class="cb-mobile-panel">
    <span class="cb-mobile-tagline">{{ tagline }}</span>
    <a href="{{ y_btn_link }}" class="cb-mobile-ybtn">{{ y_btn_text }}&nbsp;&nbsp;&#10230;</a>
  </div>

  <!-- HERO: two stacked image bands -->
  <div class="cb-hero">

    <!-- TOP band: pure illustration, no text -->
    <div class="cb-top">
      {% if section.settings.bg_image_top != blank %}
        <img
          class="cb-top-img"
          src="{{ section.settings.bg_image_top | img_url: 'master' }}"
          alt="Banner top illustration"
          loading="eager"
        >
      {% endif %}
    </div>

    <!-- BOTTOM band: illustration + text overlay -->
    <div class="cb-bot">
      {% if section.settings.bg_image_bottom != blank %}
        <img
          class="cb-bot-img"
          src="{{ section.settings.bg_image_bottom | img_url: 'master' }}"
          alt="Banner bottom illustration"
          loading="eager"
        >
      {% endif %}
      <div class="cb-gradient"></div>
      <div class="cb-text">
        <h1 class="cb-heading">{{ heading }}</h1>
        <p class="cb-desc">{{ description }}</p>
        <a href="{{ b_btn_link }}" class="cb-bbtn">{{ b_btn_text }}&nbsp;&nbsp;&#8594;</a>
      </div>
    </div>

  </div>

  <!-- FOOTER -->
  <div class="cb-footer">{{ footer_text }}</div>

</div>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "header",       "content": "Navigation Bar" },
    { "type": "text",         "id": "logo_text",           "label": "Logo Text",            "default": "TISSO VISON" },
    { "type": "text",         "id": "tagline",              "label": "Center Tagline",       "default": "Find the ideal gift for your loved ones." },
    { "type": "text",         "id": "yellow_button_text",   "label": "Yellow Button Text",   "default": "CHOOSE GIFT" },
    { "type": "url",          "id": "yellow_button_link",   "label": "Yellow Button Link" },
    { "type": "header",       "content": "Main Content" },
    { "type": "text",         "id": "heading",              "label": "Main Heading",         "default": "The Gift Guide" },
    { "type": "textarea",     "id": "description",          "label": "Description",          "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season." },
    { "type": "text",         "id": "black_button_text",    "label": "Black Button Text",    "default": "SHOP NOW" },
    { "type": "url",          "id": "black_button_link",    "label": "Black Button Link" },
    { "type": "header",       "content": "Background Images" },
    { "type": "image_picker", "id": "bg_image_top",         "label": "Top Band Image (upper half)" },
    { "type": "image_picker", "id": "bg_image_bottom",      "label": "Bottom Band Image (lower half — behind text)" },
    { "type": "header",       "content": "Footer" },
    { "type": "text",         "id": "footer_text",          "label": "Footer Text",          "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL" }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}