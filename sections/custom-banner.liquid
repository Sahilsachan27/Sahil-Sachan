{% comment %} Custom Banner Section {% endcomment %}

{%- liquid
  assign logo_text = section.settings.logo_text | default: 'TISSO VISON'
  assign tagline = section.settings.tagline | default: 'Find the ideal gift for your loved ones.'
  assign yellow_btn_text = section.settings.yellow_button_text | default: 'CHOOSE GIFT'
  assign yellow_btn_link = section.settings.yellow_button_link | default: '#'
  assign heading = section.settings.heading | default: 'The Gift Guide'
  assign description = section.settings.description | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.'
  assign black_btn_text = section.settings.black_button_text | default: 'SHOP NOW'
  assign black_btn_link = section.settings.black_button_link | default: '#'
  assign footer_text = section.settings.footer_text | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL'
-%}

<section class="custom-banner-section">
  <!-- Top Navigation Bar -->
  <div class="cb-top-bar">
    <div class="cb-top-left">
      <span class="cb-logo">{{ logo_text }}</span>
    </div>
    <div class="cb-top-center">
      <span class="cb-tagline">{{ tagline }}</span>
    </div>
    <div class="cb-top-right">
      <a href="{{ yellow_btn_link }}" class="cb-yellow-btn">
        {{ yellow_btn_text }} <span>→</span>
      </a>
    </div>
  </div>

  <!-- Main Banner Area (Simplified 2-Column Layout) -->
  <div class="cb-main-area">
    <div class="cb-left-column">
      <h1 class="cb-heading">{{ heading }}</h1>
      <p class="cb-description">{{ description }}</p>
      
      <a href="{{ black_btn_link }}" class="cb-black-btn">
        {{ black_btn_text }} <span>→</span>
      </a>
    </div>
    
    <div class="cb-right-column">
      {% if section.settings.bg_image != blank %}
        <img src="{{ section.settings.bg_image | img_url: 'master' }}" alt="{{ section.settings.bg_image.alt | escape }}" class="cb-simple-img">
      {% endif %}
      {% if section.settings.image_2 != blank %}
        <img src="{{ section.settings.image_2 | img_url: 'master' }}" alt="Illustration 2" class="cb-simple-img">
      {% endif %}
      {% if section.settings.image_3 != blank %}
        <img src="{{ section.settings.image_3 | img_url: 'master' }}" alt="Illustration 3" class="cb-simple-img">
      {% endif %}
      {% if section.settings.image_4 != blank %}
        <img src="{{ section.settings.image_4 | img_url: 'master' }}" alt="Illustration 4" class="cb-simple-img">
      {% endif %}
    </div>
  </div>

  <!-- Footer Banner -->
  <div class="cb-footer">
    <p>{{ footer_text }}</p>
  </div>
</section>

<style>
  .custom-banner-section {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #fff;
    margin: 0;
    padding: 0;
  }

  /* Top Bar */
  .cb-top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 5%;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
  }
  
  .cb-top-left { flex: 1; display: flex; justify-content: flex-start; }
  .cb-top-center { flex: 2; display: flex; justify-content: center; text-align: center; }
  .cb-top-right { flex: 1; display: flex; justify-content: flex-end; }

  .cb-logo { font-size: 18px; font-weight: 700; letter-spacing: 1px; color: #000; text-transform: uppercase; }
  .cb-tagline { font-size: 14px; color: #333; }
  
  .cb-yellow-btn {
    display: inline-flex;
    align-items: center;
    background: #FFD700;
    color: #000;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .cb-yellow-btn:hover { background: #e6c200; }
  .cb-yellow-btn span { margin-left: 8px; }

  /* Main Area - 2 Columns */
  .cb-main-area {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    padding: 80px 5%;
    background: #fff;
    gap: 40px;
  }

  .cb-left-column {
    flex: 1;
    min-width: 300px;
  }

  .cb-right-column {
    flex: 1.2;
    min-width: 300px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .cb-simple-img {
    max-width: 100%;
    height: auto;
    max-height: 450px;
    object-fit: contain;
  }

  /* Specific styles to arrange multiple images neatly if they upload the individual pieces */
  .cb-right-column img:nth-child(2),
  .cb-right-column img:nth-child(3),
  .cb-right-column img:nth-child(4) {
    max-width: 45%; 
    max-height: 200px;
  }

  .cb-heading {
    font-size: 56px;
    font-weight: 700;
    margin: 0 0 20px 0;
    color: #000;
    line-height: 1.1;
  }

  .cb-description {
    font-size: 16px;
    color: #333;
    line-height: 1.6;
    margin: 0 0 35px 0;
  }

  .cb-black-btn {
    display: inline-flex;
    align-items: center;
    background: #000;
    color: #fff;
    padding: 14px 36px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .cb-black-btn:hover { background: #333; }
  .cb-black-btn span { margin-left: 12px; }

  /* Footer */
  .cb-footer {
    background: #f8f8f8;
    padding: 15px 20px;
    text-align: center;
    border-top: 1px solid #eee;
  }
  .cb-footer p {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    color: #666;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cb-top-bar { flex-direction: column; gap: 15px; padding: 20px; }
    .cb-main-area { padding: 40px 5%; flex-direction: column-reverse; text-align: center; }
    .cb-heading { font-size: 40px; }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "header",
      "content": "Navigation Bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Center Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "yellow_button_text",
      "label": "Yellow Button Text",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "yellow_button_link",
      "label": "Yellow Button Link"
    },
    {
      "type": "header",
      "content": "Main Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "black_button_text",
      "label": "Black Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "black_button_link",
      "label": "Black Button Link"
    },
    {
      "type": "header",
      "content": "Images (Upload 1 big pattern OR multiple pieces)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Image 1 (Main Illustration or Camera)"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 (e.g. Watch)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 (e.g. Lens)"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4 (Optional)"
    },
    {
      "type": "header",
      "content": "Footer Area"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}