{% comment %} Custom Banner Section {% endcomment %}

{%- liquid
  assign logo_text   = section.settings.logo_text           | default: 'TISSO VISON'
  assign tagline     = section.settings.tagline              | default: 'Find the ideal gift for your loved ones.'
  assign y_btn_text  = section.settings.yellow_button_text   | default: 'CHOOSE GIFT'
  assign y_btn_link  = section.settings.yellow_button_link   | default: '#'
  assign heading     = section.settings.heading              | default: 'The Gift Guide'
  assign description = section.settings.description          | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.'
  assign b_btn_text  = section.settings.black_button_text    | default: 'SHOP NOW'
  assign b_btn_link  = section.settings.black_button_link    | default: '#'
  assign footer_text = section.settings.footer_text          | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL'
-%}

{%- if section.settings.bg_image_top != blank -%}
  {%- assign top_url = section.settings.bg_image_top | img_url: 'master' -%}
{%- endif -%}
{%- if section.settings.bg_image_bottom != blank -%}
  {%- assign bot_url = section.settings.bg_image_bottom | img_url: 'master' -%}
{%- endif -%}

<!-- All critical layout is via inline styles so Dawn theme cannot override them -->
<div style="width:100%;font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',Arial,sans-serif;-webkit-font-smoothing:antialiased;">

  <!-- ══ NAV BAR (50px) ══ -->
  <div style="display:flex;align-items:center;justify-content:space-between;height:50px;padding:0 40px;background:#ffffff;border-bottom:1px solid #e8e8e8;">
    <span style="font-size:15px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#000;flex-shrink:0;">{{ logo_text }}</span>
    <span style="font-size:14px;color:#333;text-align:center;flex:1;padding:0 20px;">{{ tagline }}</span>
    <a href="{{ y_btn_link }}" class="tisso-ybtn" style="display:inline-flex;align-items:center;background:#FFD600;color:#000;padding:10px 22px;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;flex-shrink:0;">
      {{ y_btn_text }}&nbsp;&nbsp;&#8594;
    </a>
  </div>

  <!-- ══ TOP IMAGE BAND (245px) — pure illustration, no text ══ -->
  <div style="position:relative;width:100%;height:245px;background:#ffffff;overflow:hidden;">
    {%- if top_url != blank -%}
      <img src="{{ top_url }}" alt="" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center center;display:block;z-index:0;">
    {%- endif -%}
  </div>

  <!-- ══ BOTTOM IMAGE BAND (245px) — illustration + text overlay ══ -->
  <div style="position:relative;width:100%;height:245px;background:#ffffff;overflow:hidden;">

    <!-- Background image -->
    {%- if bot_url != blank -%}
      <img src="{{ bot_url }}" alt="" style="position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;object-position:center center;display:block;z-index:0;">
    {%- endif -%}

    <!-- White left-to-right gradient so text is readable -->
    <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:linear-gradient(to right,rgba(255,255,255,0.96) 0%,rgba(255,255,255,0.75) 28%,rgba(255,255,255,0.00) 55%);z-index:1;pointer-events:none;"></div>

    <!-- Text overlay: heading, description, button -->
    <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);z-index:2;max-width:380px;background:transparent;">
      <h1 style="font-size:46px;font-weight:800;line-height:1.05;color:#000;margin:0 0 12px 0;padding:0;background:transparent;">{{ heading }}</h1>
      <p style="font-size:14px;line-height:1.6;color:#222;margin:0 0 20px 0;padding:0;background:transparent;">{{ description }}</p>
      <a href="{{ b_btn_link }}" class="tisso-bbtn" style="display:inline-flex;align-items:center;background:#000;color:#fff;padding:12px 26px;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;">
        {{ b_btn_text }}&nbsp;&nbsp;&#8594;
      </a>
    </div>

  </div>

  <!-- ══ FOOTER BAR (40px) ══ -->
  <div style="display:flex;align-items:center;justify-content:center;height:40px;background:#efefef;border-top:1px solid #ddd;font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#555;">
    {{ footer_text }}
  </div>

</div>

<!-- Only hover effects need a <style> block — Dawn cannot affect hover transitions -->
<style>
  .tisso-ybtn:hover { background: #e6c000 !important; letter-spacing: 0.12em !important; }
  .tisso-bbtn:hover { background: #333 !important; letter-spacing: 0.12em !important; }

  @media (max-width: 768px) {
    .tisso-top-band-wrap  { height: 180px !important; }
    .tisso-bot-band-wrap  { height: auto !important; min-height: 200px !important; padding-bottom: 24px !important; }
    .tisso-bot-text       { position: static !important; transform: none !important; padding: 24px 20px 0 !important; }
    .tisso-bot-h1         { font-size: 32px !important; }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "header",    "content": "Navigation Bar" },
    { "type": "text",      "id": "logo_text",           "label": "Logo Text",            "default": "TISSO VISON" },
    { "type": "text",      "id": "tagline",              "label": "Center Tagline",       "default": "Find the ideal gift for your loved ones." },
    { "type": "text",      "id": "yellow_button_text",   "label": "Yellow Button Text",   "default": "CHOOSE GIFT" },
    { "type": "url",       "id": "yellow_button_link",   "label": "Yellow Button Link" },
    { "type": "header",    "content": "Main Content" },
    { "type": "text",      "id": "heading",              "label": "Main Heading",         "default": "The Gift Guide" },
    { "type": "textarea",  "id": "description",          "label": "Description",          "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season." },
    { "type": "text",      "id": "black_button_text",    "label": "Black Button Text",    "default": "SHOP NOW" },
    { "type": "url",       "id": "black_button_link",    "label": "Black Button Link" },
    { "type": "header",    "content": "Background Images" },
    { "type": "image_picker", "id": "bg_image_top",     "label": "Top Band Image (upper half of hero)" },
    { "type": "image_picker", "id": "bg_image_bottom",  "label": "Bottom Band Image (lower half — behind text)" },
    { "type": "header",    "content": "Footer" },
    { "type": "text",      "id": "footer_text",          "label": "Footer Text",          "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL" }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}