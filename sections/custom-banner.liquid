{% comment %} Custom Banner Section {% endcomment %}

<section class="custom-banner">
  <div class="banner-illustration">
    <img src="{{ section.settings.bg_image | img_url: 'master' }}" alt="banner background">
  </div>
  
  <div class="banner-content">
    <p class="banner-logo">{{ section.settings.logo_text }}</p>
    <p class="banner-tagline">{{ section.settings.tagline }}</p>
    
    <h1 class="banner-heading">{{ section.settings.heading }}</h1>
    <p class="banner-subtext">{{ section.settings.subtext }}</p>
    
    <a href="{{ section.settings.button_link }}" class="banner-btn">
      {{ section.settings.button_text }}
      <span>→</span>
    </a>
    
    <p class="banner-footer-text">{{ section.settings.footer_text }}</p>
  </div>
</section>

<style>
  .custom-banner {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: center;
    padding: 40px;
    overflow: hidden;
    background: #fff;
  }

  .banner-illustration {
    position: absolute;
    right: 0;
    top: 0;
    width: 60%;
    height: 100%;
    opacity: 0.3;
  }

  .banner-illustration img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    max-width: 500px;
  }

  .banner-logo {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .banner-tagline {
    font-size: 12px;
    color: #666;
    margin-bottom: 20px;
  }

  .banner-heading {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 16px;
    color: #000;
  }

  .banner-subtext {
    font-size: 14px;
    color: #444;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .banner-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: #000;
    color: #fff;
    padding: 14px 28px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .banner-btn:hover {
    background: #f0c040;
    color: #000;
    gap: 20px;
  }

  .banner-btn span {
    transition: transform 0.3s ease;
  }

  .banner-btn:hover span {
    transform: translateX(6px);
  }

  .banner-footer-text {
    margin-top: 24px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #888;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .custom-banner {
      padding: 30px 20px;
      min-height: 400px;
    }

    .banner-heading {
      font-size: 32px;
    }

    .banner-illustration {
      width: 100%;
      opacity: 0.15;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect present to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XS TO 6XL"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Illustration Image"
    }
  ],
  "presets": [
    {
      "name": "Custom Banner"
    }
  ]
}
{% endschema %}