{% comment %} Custom Banner Section {% endcomment %}

{%- liquid
  assign logo_text   = section.settings.logo_text          | default: 'TISSO VISON'
  assign tagline     = section.settings.tagline             | default: 'Find the ideal gift for your loved ones.'
  assign y_btn_text  = section.settings.yellow_button_text  | default: 'CHOOSE GIFT'
  assign y_btn_link  = section.settings.yellow_button_link  | default: '#'
  assign heading     = section.settings.heading             | default: 'The Gift Guide'
  assign description = section.settings.description         | default: 'Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season.'
  assign b_btn_text  = section.settings.black_button_text   | default: 'SHOP NOW'
  assign b_btn_link  = section.settings.black_button_link   | default: '#'
  assign footer_text = section.settings.footer_text         | default: 'SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL'
-%}

{%- comment %} TOP band — no gradient needed, no text overlay {%- endcomment -%}
{%- if section.settings.bg_image_top != blank -%}
  {%- assign top_url = section.settings.bg_image_top | img_url: 'master' -%}
  {%- assign top_bg = 'background:url(' | append: top_url | append: ') center center/cover no-repeat;' -%}
{%- else -%}
  {%- assign top_bg = 'background:#f4f4f4;' -%}
{%- endif -%}

{%- comment %} BOTTOM band — white gradient merged inline so Dawn CSS cannot override it {%- endcomment -%}
{%- if section.settings.bg_image_bottom != blank -%}
  {%- assign bot_url = section.settings.bg_image_bottom | img_url: 'master' -%}
  {%- assign bot_bg = 'background:linear-gradient(to right,rgba(255,255,255,0.95) 0%,rgba(255,255,255,0.75) 28%,rgba(255,255,255,0.00) 56%),url(' | append: bot_url | append: ') center center/cover no-repeat;' -%}
{%- else -%}
  {%- assign bot_bg = 'background:#ececec;' -%}
{%- endif -%}

<div class="tisso-banner">

  <!-- ── NAV BAR ── -->
  <div class="tisso-nav">
    <span class="tisso-logo">{{ logo_text }}</span>
    <span class="tisso-tagline">{{ tagline }}</span>
    <a href="{{ y_btn_link }}" class="tisso-ybtn">
      {{ y_btn_text }}&nbsp;&nbsp;&#8594;
    </a>
  </div>

  <!-- ── HERO: two stacked image bands ── -->
  <div class="tisso-hero">

    <!-- TOP band: pure illustration, no text -->
    <div class="tisso-top-band" style="{{ top_bg }}"></div>

    <!-- BOTTOM band: illustration + text overlay on the left -->
    <div class="tisso-bot-band" style="{{ bot_bg }}">
      <div class="tisso-text">
        <h1 class="tisso-heading">{{ heading }}</h1>
        <p class="tisso-desc">{{ description }}</p>
        <a href="{{ b_btn_link }}" class="tisso-bbtn">
          {{ b_btn_text }}&nbsp;&nbsp;&#8594;
        </a>
      </div>
    </div>

  </div>

  <!-- ── FOOTER ── -->
  <div class="tisso-footer">{{ footer_text }}</div>

</div>

<style>
  /* Reset */
  .tisso-banner, .tisso-banner * { box-sizing: border-box; margin: 0; padding: 0; }

  .tisso-banner {
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    background: #fff;
  }

  /* ── NAV BAR – 50px fixed height ── */
  .tisso-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 50px;
    padding: 0 40px;
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
  }

  .tisso-logo {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    flex-shrink: 0;
  }

  .tisso-tagline {
    font-size: 14px;
    color: #333;
    text-align: center;
    flex: 1;
    padding: 0 20px;
  }

  .tisso-ybtn {
    display: inline-flex;
    align-items: center;
    background: #FFD600;
    color: #000;
    padding: 10px 22px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.2s ease, letter-spacing 0.25s ease;
  }
  .tisso-ybtn:hover { background: #e6c000; letter-spacing: 0.12em; }

  /* ── HERO WRAPPER – total 490px = two 245px bands ── */
  .tisso-hero {
    width: 100%;
    height: 490px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* TOP band – 245px, pure image, no text */
  .tisso-top-band {
    width: 100%;
    height: 245px;
    flex-shrink: 0;
    background-color: #f4f4f4;
    /* background set via inline style */
  }

  /* BOTTOM band – 245px, image + text overlay */
  .tisso-bot-band {
    width: 100%;
    height: 245px;
    flex-shrink: 0;
    position: relative;
    background-color: #ececec;
    /* background (gradient+image) set via inline style */
    overflow: hidden;
  }

  /* Text block sits centred vertically on the left */
  .tisso-text {
    position: absolute;
    top: 50%;
    left: 40px;
    transform: translateY(-50%);
    z-index: 2;
    max-width: 380px;
    background: transparent !important;
  }

  .tisso-heading {
    font-size: 46px;
    font-weight: 800;
    line-height: 1.05;
    color: #000;
    margin-bottom: 12px;
    background: transparent !important;
  }

  .tisso-desc {
    font-size: 14px;
    line-height: 1.6;
    color: #222;
    margin-bottom: 20px;
    background: transparent !important;
  }

  .tisso-bbtn {
    display: inline-flex;
    align-items: center;
    background: #000;
    color: #fff;
    padding: 12px 26px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s ease, letter-spacing 0.25s ease;
  }
  .tisso-bbtn:hover { background: #333; letter-spacing: 0.12em; }

  /* ── FOOTER – 40px fixed height ── */
  /* TOTAL: 50 + 490 + 40 = 580px — never scrolls */
  .tisso-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    background: #efefef;
    border-top: 1px solid #ddd;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .tisso-nav { flex-wrap: wrap; height: auto; padding: 12px 20px; gap: 10px; }
    .tisso-tagline { order: 3; flex: 1 0 100%; padding: 0; }
    .tisso-hero { height: auto; }
    .tisso-top-band { height: 200px; }
    .tisso-bot-band { height: auto; min-height: 220px; padding: 30px 20px; }
    .tisso-text { position: static; transform: none; max-width: 100%; }
    .tisso-heading { font-size: 34px; }
  }
</style>

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "header", "content": "Navigation Bar" },
    { "type": "text",   "id": "logo_text",           "label": "Logo Text",            "default": "TISSO VISON" },
    { "type": "text",   "id": "tagline",              "label": "Center Tagline",       "default": "Find the ideal gift for your loved ones." },
    { "type": "text",   "id": "yellow_button_text",   "label": "Yellow Button Text",   "default": "CHOOSE GIFT" },
    { "type": "url",    "id": "yellow_button_link",   "label": "Yellow Button Link" },
    { "type": "header", "content": "Main Content" },
    { "type": "text",   "id": "heading",              "label": "Main Heading",         "default": "The Gift Guide" },
    { "type": "textarea", "id": "description",        "label": "Description",          "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gift to delight your loved ones this holiday season." },
    { "type": "text",   "id": "black_button_text",    "label": "Black Button Text",    "default": "SHOP NOW" },
    { "type": "url",    "id": "black_button_link",    "label": "Black Button Link" },
    { "type": "header", "content": "Background Images" },
    { "type": "image_picker", "id": "bg_image_top",    "label": "Top Band Image (upper half)" },
    { "type": "image_picker", "id": "bg_image_bottom", "label": "Bottom Band Image (lower half — behind text)" },
    { "type": "header", "content": "Footer" },
    { "type": "text",   "id": "footer_text",          "label": "Footer Text",          "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 9XL" }
  ],
  "presets": [{ "name": "Custom Banner" }]
}
{% endschema %}